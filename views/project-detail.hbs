<div class="container mt-5" style="max-width: 800px;">
  <!-- Tombol Kembali -->
  <div class="mb-4">
    <a href="/my-project" class="text-decoration-none text-secondary">
      &larr; Kembali ke daftar project
    </a>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <!-- Gambar Full Width -->
    <img src="{{project.image}}" class="card-img-top" alt="{{project.nama}}" style="max-height: 400px; object-fit: cover;" />
    
    <div class="card-body p-4 p-md-5">
      <!-- Header Konten -->
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <h2 class="fw-bold mb-1">{{project.nama}}</h2>
          <p class="text-muted small mb-0">Project Details</p>
        </div>
        
        {{#if project.link}}
          <a href="{{project.link}}" target="_blank" class="btn btn-dark px-4 rounded-pill">
            Kunjungi Web
          </a>
        {{/if}}
      </div>

      <hr class="text-muted opacity-25 mb-4">

      <!-- Deskripsi -->
      <h6 class="fw-semibold text-secondary mb-3">TENTANG PROJECT</h6>
      <p class="card-text lh-lg" style="text-align: justify;">
        {{project.deskripsi}}
      </p>

    </div>
  </div>
</div>
