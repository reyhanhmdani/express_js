<div class="row justify-content-center py-4">
  <div class="col-md-8 col-lg-6">
    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
      <div class="text-center mb-4">
        <h2 class="fw-bold text-dark">Get In Touch</h2>
        <p class="text-secondary">Have a project in mind? Let's talk about it.</p>
      </div>
      
      <form>
        <div class="mb-3">
          <label for="name" class="form-label fw-semibold">Name</label>
          <input type="text" class="form-control form-control-lg rounded-3 bg-light border-0" id="name" placeholder="Rey">
        </div>
        <div class="mb-3">
          <label for="email" class="form-label fw-semibold">Email address</label>
          <input type="email" class="form-control form-control-lg rounded-3 bg-light border-0" id="email" placeholder="name@example.com">
        </div>
        <div class="mb-3">
          <label for="subject" class="form-label fw-semibold">Subject</label>
          <select class="form-select form-select-lg rounded-3 bg-light border-0" id="subject">
            <option selected>Select a subject...</option>
            <option value="1">Frontend Development</option>
            <option value="2">Backend Development</option>
            <option value="3">Fullstack Project</option>
          </select>
        </div>
        <div class="mb-4">
          <label for="message" class="form-label fw-semibold">Message</label>
          <textarea class="form-control form-control-lg rounded-3 bg-light border-0" id="message" rows="4" placeholder="Write your message here..."></textarea>
        </div>
        <div class="d-grid">
          <button type="submit" class="btn btn-dark btn-lg rounded-pill fw-semibold">Send Message</button>
        </div>
      </form>
    </div>
  </div>
</div>